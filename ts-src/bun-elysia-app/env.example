# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Example for local PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/cacao_msme"

# Example for Neon.tech (serverless Postgres):
# DATABASE_URL="postgresql://username:password@ep-example.neon.tech/dbname?sslmode=require"
